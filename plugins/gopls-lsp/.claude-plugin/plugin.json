    "homepage": "https://gitlab.com/kilianpaquier/ai-marketplace/plugins/gopls",

    "lspServers": {
        "gopls": {
            "command": "gopls",
            "extensionToLanguage": {
                ".go": "go"
            }
        }
    }
}
