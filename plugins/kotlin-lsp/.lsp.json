{
    "lspServers": {
        "kotlin-lsp": {
            "command": "kotlin-lsp",
            "args": [
                "--stdio"
            ],
            "extensionToLanguage": {
                ".kt": "kotlin",
                ".kts": "kotlin"
            },
            "fileExtensions": {
                ".kt": "kotlin",
                ".kts": "kotlin"
            },
            "startupTimeout": 120000
        }
    }
}
