{
    "name": "kotlin-lsp",
    "description": "Kotlin language server for code intelligence",
    "version": "0.1.0",
    "license": "MIT",
    "repository": "https://github.com/Kotlin/kotlin-lsp",
    "homepage": "https://gitlab.com/kilianpaquier/ai-marketplace/plugins/kotlin-lsp",

    "lspServers": {
        "kotlin": {
            "command": "kotlin-lsp",
            "args": [
                "--stdio"
            ],
            "fileExtensions": {
                ".kt": "kotlin",
                ".kts": "kotlin"
            },
            "startupTimeout": 120000
        }
    }
}
