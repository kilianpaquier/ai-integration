// https://docs.renovatebot.com/configuration-options/

{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",

    "packageRules": [
        {
            "matchFileNames": ["/apm.yml/"],
            "postUpgradeTasks": {
                "commands": ["./scripts/sh/renovate.sh"],
                "executionMode": "branch"
            }
        }
    ]
}
